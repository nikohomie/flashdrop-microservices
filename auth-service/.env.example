# auth-service — variables de entorno (copiar a .env, NUNCA versionar)

# ---- JWT (RS256, firma asimétrica) ----
# Producción: proveer las claves RSA en PEM (una sola línea con \n o multilínea).
#   openssl genpkey -algorithm RSA -pkcs8 -out private.pem
#   openssl rsa -pubout -in private.pem -out public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# Dev sin claves: permitir clave efímera generada al arranque (NO en producción).
JWT_ALLOW_EPHEMERAL=true
JWT_ACCESS_MIN=15
JWT_REFRESH_DAYS=30

# ---- Rate limiting de login (S-08) ----
AUTH_RL_MAX=5
AUTH_RL_WINDOW=300

# ---- Supabase (REST API, no JDBC) ----
# Pedir SUPABASE_URL al líder del equipo
SUPABASE_URL=http://supabasekong-wymwq8rktid7ov678oe4va90.76.13.169.150.sslip.io
# Pedir SUPABASE_SERVICE_ROLE_KEY al líder del equipo (NUNCA versionar el valor real)
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ---- Profile activo ----
# Para correr contra Supabase real, usar perfil "supabase"
SPRING_PROFILES_ACTIVE=supabase

PORT=8081

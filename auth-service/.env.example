# auth-service — variables de entorno (copiar a .env, NUNCA versionar)

# ---- JWT (RS256, firma asimétrica) ----
# Producción: proveer las claves RSA en PEM (una sola línea con \n o multilínea).
#   openssl genpkey -algorithm RSA -pkcs8 -out private.pem
#   openssl rsa -pubout -in private.pem -out public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# Dev sin claves: permitir clave efímera generada al arranque (NO en producción).
JWT_ALLOW_EPHEMERAL=true
JWT_ACCESS_MIN=15
JWT_REFRESH_DAYS=30

# ---- Rate limiting de login (S-08) ----
AUTH_RL_MAX=5
AUTH_RL_WINDOW=300

# ---- Base de datos ----
# Local (Docker/Postgres):
#   DB_URL=jdbc:postgresql://localhost:5432/flashdrop_auth
#   DB_USER=auth_service
#
# Supabase (PostgreSQL gestionado, requiere SSL). Datos en: Project Settings > Database.
#   Conexión directa (IPv6):
#     DB_URL=jdbc:postgresql://db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require
#     DB_USER=postgres
#   Session pooler (IPv4, si tu red no tiene IPv6) — recomendado para Flyway:
#     DB_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
#     DB_USER=postgres.<PROJECT_REF>
DB_URL=jdbc:postgresql://localhost:5432/flashdrop_auth
DB_USER=auth_service
DB_PASSWORD=

PORT=8081

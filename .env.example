# =========================================================================
# CONFIGURACIÓN PARA DESARROLLO LOCAL (Plantilla)
# Copia este archivo a `.env` y configura tus valores.
# =========================================================================

# -------------------------------------------------------------------------
# 1. Base de Datos (PostgreSQL)
# -------------------------------------------------------------------------
POSTGRES_USER=auth_service
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=flashdrop_auth

# URLs para los servicios Spring Boot
DB_URL=jdbc:postgresql://localhost:5432/flashdrop_auth
DB_USER=auth_service
DB_PASSWORD=devpassword

# -------------------------------------------------------------------------
# 2. Seguridad y JWT (Auth Service)
# -------------------------------------------------------------------------
# En desarrollo (local), auth-service generará un par de claves efímeras 
# en cada reinicio si no se proveen estas claves. 
# Para probar el catalog-service protegido con JWT, debes copiar aquí la 
# CLAVE PÚBLICA que el auth-service escupe en sus logs al iniciar, o bien 
# generar tu propio par de claves RSA (PEM) y pegarlas abajo.

# Ejemplo de clave pública (reemplaza con la tuya):
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...\n-----END PUBLIC KEY-----"

# -------------------------------------------------------------------------
# 3. Puertos Locales
# -------------------------------------------------------------------------
AUTH_SERVICE_PORT=8081
CATALOG_SERVICE_PORT=8082
API_GATEWAY_PORT=8080
